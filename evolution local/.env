# Servidor y Dominio Local
SERVER_URL=http://localhost:8080
CORS_ORIGIN=*
TZ=America/Argentina/Buenos_Aires
DOCKER_ENV=true

# Seguridad
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=GympleEvolutionSecret2026

# Base de Datos Local (Actualizada con tus credenciales)
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:123@host.docker.internal:5432/evolution_db?schema=public

# Caché Redis (Se mantiene apuntando al contenedor del compose)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://default:gymple_redis_local@redis:6379/1

# Resolución de WhatsApp Web
QRCODE_LIMIT=30

# Webhooks
WEBHOOK_GLOBAL_ENABLED=false