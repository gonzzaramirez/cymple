generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilitySource {
  WEEKLY
  SPECIFIC_DATE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ATTENDED
  ABSENT
  CANCELLED
}

enum WaStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageType {
  APPOINTMENT_CREATED
  APPOINTMENT_REMINDER
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  PATIENT_REPLY
  PAYMENT_REMINDER
  SYSTEM
}

enum AppointmentModality {
  PRESENCIAL
  VIRTUAL
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum AccountRole {
  INDEPENDENT
  CENTER_ADMIN
  CENTER_MEMBER
}

// Centro médico / clínica. Actúa como tenant padre.
model Organization {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  email          String   @unique
  passwordHash   String
  phone          String?
  timezone       String   @default("America/Argentina/Buenos_Aires")
  isActive       Boolean  @default(true)
  waInstanceName String?
  waStatus       WaStatus @default(DISCONNECTED)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professionals    Professional[]
  patients         Patient[]
  appointments     Appointment[]
  revenues         Revenue[]
  expenses         Expense[]
  messageLogs      MessageLog[]
  messageTemplates MessageTemplate[]
  notifications    Notification[]
  webhookEventLogs WebhookEventLog[]
}

model Professional {
  id                  String   @id @default(cuid())
  slug                String   @unique
  fullName            String
  email               String   @unique
  passwordHash        String
  phone               String?
  specialty           String?
  timezone            String   @default("America/Argentina/Buenos_Aires")
  consultationMinutes Int      @default(30)
  bufferMinutes       Int      @default(10)
  minRescheduleHours  Int      @default(4)
  standardFee         Decimal  @db.Decimal(10, 2)
  reminderHours       Int      @default(24)
  dailyDigestEnabled  Boolean  @default(false)
  dailyDigestTime     String   @default("08:00")
  autoConfirmHours    Int?
  paymentAlias        String?
  waInstanceName      String?
  waStatus            WaStatus @default(DISCONNECTED)
  isActive            Boolean  @default(true)
  organizationId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization       Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  weeklyAvailability WeeklyAvailability[]
  specificDateSlots  SpecificDateAvailability[]
  patients           Patient[]
  appointments       Appointment[]
  revenues           Revenue[]
  expenses           Expense[]
  messageLogs        MessageLog[]
  webhookEventLogs   WebhookEventLog[]
  notifications      Notification[]
  messageTemplates   MessageTemplate[]

  @@index([organizationId])
}

model WeeklyAvailability {
  id             String   @id @default(cuid())
  professionalId String
  weekday        Weekday
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional Professional        @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  ranges       AvailabilityRange[]

  @@unique([professionalId, weekday])
  @@index([professionalId])
}

model SpecificDateAvailability {
  id             String   @id @default(cuid())
  professionalId String
  date           DateTime @db.Date
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional   Professional               @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  ranges         AvailabilityRange[]
  slotCapacities AvailabilitySlotCapacity[]

  @@unique([professionalId, date])
  @@index([professionalId, date])
}

model AvailabilityRange {
  id                         String   @id @default(cuid())
  startTime                  String
  endTime                    String
  capacity                   Int?
  weeklyAvailabilityId       String?
  specificDateAvailabilityId String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  weeklyAvailability       WeeklyAvailability?       @relation(fields: [weeklyAvailabilityId], references: [id], onDelete: Cascade)
  specificDateAvailability SpecificDateAvailability? @relation(fields: [specificDateAvailabilityId], references: [id], onDelete: Cascade)

  @@index([weeklyAvailabilityId])
  @@index([specificDateAvailabilityId])
}

model AvailabilitySlotCapacity {
  id                         String   @id @default(cuid())
  specificDateAvailabilityId String
  startTime                  String
  capacity                   Int
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  specificDateAvailability SpecificDateAvailability @relation(fields: [specificDateAvailabilityId], references: [id], onDelete: Cascade)

  @@unique([specificDateAvailabilityId, startTime])
  @@index([specificDateAvailabilityId])
}

model Patient {
  id             String    @id @default(cuid())
  professionalId String?
  organizationId String?
  firstName      String
  lastName       String
  phone          String?
  email          String?
  dni            String?
  birthDate      DateTime? @db.Date
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  messageLogs  MessageLog[]

  // Solo professionals: unique phone/dni per professional
  @@unique([professionalId, phone])
  @@unique([professionalId, dni])
  // Center patients: unique phone/dni per org (nulls are distinct in PG, so only applies when organizationId is set)
  @@unique([organizationId, phone])
  @@unique([organizationId, dni])
  @@index([professionalId, lastName, firstName])
  @@index([professionalId, createdAt])
  @@index([organizationId, lastName, firstName])
  @@index([organizationId, createdAt])
}

model Appointment {
  id                    String              @id @default(cuid())
  professionalId        String
  organizationId        String?
  patientId             String
  startAt               DateTime
  endAt                 DateTime
  durationMinutes       Int
  bufferMinutes         Int
  status                AppointmentStatus   @default(PENDING)
  modality              AppointmentModality @default(PRESENCIAL)
  fee                   Decimal             @db.Decimal(10, 2)
  reason                String?
  cancelledAt           DateTime?
  attendedAt            DateTime?
  reminderScheduledFor  DateTime?
  reminderSentAt        DateTime?
  reminderJobId         String?
  paymentReminderSentAt DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  professional Professional  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  revenue      Revenue?
  messageLogs  MessageLog[]

  @@index([professionalId, startAt])
  @@index([professionalId, status, startAt])
  @@index([patientId, startAt])
  @@index([organizationId, startAt])
  @@index([organizationId, status, startAt])
}

model Revenue {
  id             String         @id @default(cuid())
  professionalId String?
  organizationId String?
  appointmentId  String?        @unique
  amount         Decimal        @db.Decimal(10, 2)
  occurredAt     DateTime
  notes          String?
  paymentMethod  PaymentMethod?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([professionalId, occurredAt])
  @@index([organizationId, occurredAt])
}

model Expense {
  id             String   @id @default(cuid())
  professionalId String?
  organizationId String?
  concept        String
  amount         Decimal  @db.Decimal(10, 2)
  occurredAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([professionalId, occurredAt])
  @@index([organizationId, occurredAt])
}

model MessageLog {
  id             String           @id @default(cuid())
  professionalId String
  organizationId String?
  patientId      String?
  appointmentId  String?
  direction      MessageDirection
  messageType    MessageType
  toPhone        String?
  fromPhone      String?
  content        String
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime         @default(now())

  professional Professional  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([professionalId, createdAt])
  @@index([professionalId, messageType])
  @@index([professionalId, patientId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, patientId, createdAt])
}

model WebhookEventLog {
  id             String    @id @default(cuid())
  professionalId String?
  organizationId String?
  source         String
  eventType      String
  payload        Json
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([professionalId, createdAt])
  @@index([organizationId, createdAt])
  @@index([source, eventType])
}

model Notification {
  id             String    @id @default(cuid())
  professionalId String?
  organizationId String?
  type           String
  title          String
  body           String?
  link           String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([professionalId, readAt, createdAt])
  @@index([organizationId, readAt, createdAt])
}

model MessageTemplate {
  id             String      @id @default(cuid())
  professionalId String?
  organizationId String?
  messageType    MessageType
  isEnabled      Boolean     @default(true)
  body           String      @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([professionalId, messageType])
  @@unique([organizationId, messageType])
  @@index([professionalId])
  @@index([organizationId])
}
