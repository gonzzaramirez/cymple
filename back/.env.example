# Entorno (development | production | test). Afecta logs (pino-pretty en desarrollo).
NODE_ENV=development

# Puerto HTTP del API NestJS
PORT=3080

# PostgreSQL — URL de conexión para Prisma
# Ejemplo: postgresql://usuario:contraseña@localhost:5432/medagenda
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/medagenda"

# Firma de tokens JWT (usa un valor largo y aleatorio en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Caducidad del access token (formato compatible con jsonwebtoken, ej. 12h, 7d)
JWT_EXPIRES_IN=12h

# Token compartido para validar webhooks de Evolution (opcional; si no se define, el controlador puede no validar)
# EVOLUTION_WEBHOOK_TOKEN=

# Evolution API (VPS). Cabecera apikey en cada request.
# EVOLUTION_API_URL=https://tu-vps.example.com
# EVOLUTION_API_KEY=

# URL pública del API (sin barra final) para registrar el webhook al crear instancia: {APP_PUBLIC_URL}/v1/webhooks/whatsapp
# APP_PUBLIC_URL=https://api.tu-dominio.com
