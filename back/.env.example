# Base de datos PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:REEMPLAZAR_PASSWORD@HOST:5432/gymple_bd"

# API
PORT=3080
NODE_ENV=production
TZ=America/Argentina/Buenos_Aires

# Auth
JWT_SECRET=REEMPLAZAR_POR_SECRETO_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=12h

# Multi-tenant por subdominio
BASE_DOMAIN=cymple.online
TRUST_PROXY=true

# CORS (usar dominios explícitos en producción; evitar *)
CORS_ORIGINS=https://cymple.online,https://*.cymple.online

# Evolution API
EVOLUTION_API_URL=https://wap.cymple.online
EVOLUTION_API_KEY=REEMPLAZAR_EVOLUTION_API_KEY
# EVOLUTION_WEBHOOK_TOKEN=REEMPLAZAR_WEBHOOK_TOKEN

